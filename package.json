{
  "name": "markdown-pattern-studio",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Markdown-first live preview studio with CodeMirror editor and pattern-based HTML rendering",
  "scripts": {
    "start": "node server.js",
    "md2html": "node scripts/md-to-html.mjs",
    "test:blog-embed": "node test/blog-embed-export-guard.mjs",
    "test:document-advisor": "node test/document-production-advisor-render.mjs",
    "test:embed-images": "node test/embed-local-images.mjs",
    "test:brand-designs": "node test/brand-design-integration.mjs",
    "design:collect": "node scripts/collect-design-md.mjs",
    "design:analyze": "node scripts/analyze-design-md.mjs",
    "design:update": "node scripts/collect-design-md.mjs && node scripts/analyze-design-md.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
