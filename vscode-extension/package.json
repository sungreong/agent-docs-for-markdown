{
  "name": "markdown-agent-docs",
  "displayName": "Agent Docs for Markdown",
  "description": "Browse Markdown as a source graph, package context, and write better docs with AI agent skills.",
  "version": "0.1.38",
  "publisher": "datanewbie-labs",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sungreong/md-pattern-studio"
  },
  "bugs": {
    "url": "https://github.com/sungreong/md-pattern-studio/issues"
  },
  "homepage": "https://github.com/sungreong/md-pattern-studio#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri",
    "onLanguage:markdown",
    "onView:mdStudioFileBrowser",
    "onView:mdStudioSourceGraphLauncher",
    "onCommand:mdStudioPreview.open",
    "onCommand:mdStudioPreview.refresh",
    "onCommand:mdStudioPreview.openSourceEditor",
    "onCommand:mdStudioPreview.enableAutoOnSave",
    "onCommand:mdStudioPreview.disableAutoOnSave",
    "onCommand:mdStudioPreview.openTemplateBuilder",
    "onCommand:mdStudioPreview.openSourceGraph",
    "onCommand:mdStudioPreview.initializeSourceGraphWorkspace",
    "onCommand:mdStudioPreview.updateSourceGraph",
    "onCommand:mdStudioPreview.searchSourceGraph",
    "onCommand:mdStudioPreview.openSourceIgnoreFile",
    "onCommand:mdStudioPreview.copyCodexMcpConfig",
    "onCommand:mdStudioPreview.installCodexMcp",
    "onCommand:mdStudioPreview.checkCodexMcpStatus",
    "onCommand:mdStudioPreview.removeCodexMcp",
    "onCommand:mdStudioPreview.openFileInViewer",
    "onCommand:mdStudioPreview.openFileInNewPanel",
    "onCommand:mdStudioFileBrowser.openInEditor",
    "onCommand:mdStudioPreview.transformMarkdownToHtml",
    "onCommand:mdStudioPreview.downloadSkillFolder",
    "onCommand:mdStudioPreview.diagnoseEnvironment",
    "onCommand:mdStudioPreview.focusFolder",
    "onCommand:mdStudioPreview.clearFolderFocus",
    "onCommand:mdStudioFileBrowser.refresh",
    "onCommand:mdStudioFileBrowser.sort",
    "onCommand:mdStudioFileBrowser.filter",
    "onCommand:mdStudioFileBrowser.configureExtensions",
    "onCommand:mdStudioFileBrowser.pinToTop",
    "onCommand:mdStudioFileBrowser.unpin",
    "onCommand:mdStudioFileBrowser.copyPath",
    "onCommand:mdStudioFileBrowser.copyRelativePath",
    "onCommand:mdStudioFileBrowser.copyFileName",
    "onCommand:mdStudioFileBrowser.hideItem",
    "onCommand:mdStudioFileBrowser.delete",
    "onCommand:mdStudioFileBrowser.manageHidden",
    "onCommand:mdStudioFileBrowser.search"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mdStudioFileBrowserContainer",
          "title": "Agent Docs",
          "icon": "assets/activity-md.svg"
        },
        {
          "id": "mdStudioSourceGraphContainer",
          "title": "Agent Docs Source Graph",
          "icon": "assets/activity-source-graph.svg"
        }
      ]
    },
    "views": {
      "mdStudioFileBrowserContainer": [
        {
          "id": "mdStudioFileBrowser",
          "name": "MD Studio Files",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "mdStudioSourceGraphContainer": [
        {
          "id": "mdStudioSourceGraphLauncher",
          "name": "Source Graph",
          "type": "webview",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "mdStudioPreview.open",
        "title": "MD Studio: Preview"
      },
      {
        "command": "mdStudioPreview.refresh",
        "title": "MD Studio: Refresh"
      },
      {
        "command": "mdStudioPreview.openSourceEditor",
        "title": "MD Studio: Open Source Editor",
        "icon": "$(edit)"
      },
      {
        "command": "mdStudioPreview.enableAutoOnSave",
        "title": "MD Studio: Auto Refresh Off",
        "icon": "$(circle-slash)"
      },
      {
        "command": "mdStudioPreview.disableAutoOnSave",
        "title": "MD Studio: Auto Refresh On",
        "icon": "$(sync)"
      },
      {
        "command": "mdStudioPreview.openTemplateBuilder",
        "title": "Template Builder",
        "icon": "$(combine)"
      },
      {
        "command": "mdStudioPreview.openSourceGraph",
        "title": "MD Studio: Open Source Graph",
        "icon": "$(graph)"
      },
      {
        "command": "mdStudioPreview.initializeSourceGraphWorkspace",
        "title": "MD Studio: Initialize Source Graph Workspace",
        "icon": "$(database)"
      },
      {
        "command": "mdStudioPreview.updateSourceGraph",
        "title": "MD Studio: Update Source Graph Index",
        "icon": "$(database)"
      },
      {
        "command": "mdStudioPreview.searchSourceGraph",
        "title": "MD Studio: Search Source Graph",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "mdStudioPreview.openSourceIgnoreFile",
        "title": "MD Studio: Edit Source Ignore",
        "icon": "$(exclude)"
      },
      {
        "command": "mdStudioPreview.copyCodexMcpConfig",
        "title": "MD Studio: Copy Source Graph MCP Config",
        "icon": "$(settings-gear)"
      },
      {
        "command": "mdStudioPreview.installCodexMcp",
        "title": "MD Studio: Install Source Graph MCP",
        "icon": "$(plug)"
      },
      {
        "command": "mdStudioPreview.checkCodexMcpStatus",
        "title": "MD Studio: Check Source Graph MCP Status",
        "icon": "$(pulse)"
      },
      {
        "command": "mdStudioPreview.removeCodexMcp",
        "title": "MD Studio: Remove Source Graph MCP",
        "icon": "$(trash)"
      },
      {
        "command": "mdStudioPreview.downloadSkillFolder",
        "title": "MD Studio: Install or Export Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mdStudioPreview.diagnoseEnvironment",
        "title": "MD Studio: Diagnose Environment",
        "icon": "$(pulse)"
      },
      {
        "command": "mdStudioPreview.focusFolder",
        "title": "FOCUS",
        "icon": "$(target)"
      },
      {
        "command": "mdStudioPreview.clearFolderFocus",
        "title": "Clear Focus",
        "icon": "$(eye)"
      },
      {
        "command": "mdStudioPreview.transformMarkdownToHtml",
        "title": "MD Studio: Transform Markdown to Styled HTML",
        "icon": "$(file-code)"
      },
      {
        "command": "mdStudioPreview.openFileInViewer",
        "title": "MD Studio: Open in Viewer",
        "icon": "$(open-preview)"
      },
      {
        "command": "mdStudioFileBrowser.refresh",
        "title": "MD Studio: Refresh File Browser",
        "icon": "$(refresh)"
      },
      {
        "command": "mdStudioFileBrowser.openInEditor",
        "title": "Open in Editor",
        "icon": "$(go-to-file)"
      },
      {
        "command": "mdStudioPreview.openFileInNewPanel",
        "title": "Open in New Panel",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "mdStudioFileBrowser.search",
        "title": "MD Studio: Search Files",
        "icon": "$(search)"
      },
      {
        "command": "mdStudioFileBrowser.sort",
        "title": "MD Studio: Sort Files",
        "icon": "$(list-ordered)"
      },
      {
        "command": "mdStudioFileBrowser.filter",
        "title": "MD Studio: Filter Files",
        "icon": "$(filter)"
      },
      {
        "command": "mdStudioFileBrowser.configureExtensions",
        "title": "MD Studio: File Extensions",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "mdStudioFileBrowser.pinToTop",
        "title": "Pin to Top",
        "icon": "$(pinned)"
      },
      {
        "command": "mdStudioFileBrowser.unpin",
        "title": "Unpin",
        "icon": "$(pinned)"
      },
      {
        "command": "mdStudioFileBrowser.copyPath",
        "title": "Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "mdStudioFileBrowser.copyRelativePath",
        "title": "Copy Relative Path",
        "icon": "$(copy)"
      },
      {
        "command": "mdStudioFileBrowser.copyFileName",
        "title": "Copy Name",
        "icon": "$(copy)"
      },
      {
        "command": "mdStudioFileBrowser.hideItem",
        "title": "Hide from Browser",
        "icon": "$(eye-closed)"
      },
      {
        "command": "mdStudioFileBrowser.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "mdStudioFileBrowser.manageHidden",
        "title": "MD Studio: Manage Hidden Items",
        "icon": "$(eye)"
      }
    ],
    "configuration": {
      "title": "Agent Docs for Markdown",
      "properties": {
        "mdStudioPreview.autoOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh an already-open preview when a markdown file is saved."
        },
        "mdStudioPreview.cursorSyncOnSave": {
          "type": "boolean",
          "default": true,
          "description": "After save render, move preview to the section under the active cursor."
        },
        "mdStudioPreview.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Node.js executable path used to run scripts/md-to-html.mjs."
        },
        "mdStudioPreview.cliScriptPath": {
          "type": "string",
          "default": "scripts/md-to-html.mjs",
          "description": "CLI script path. The default value uses the renderer bundled with this extension first, so generated HTML gets the latest viewer controls. Set a custom relative or absolute path to use a workspace renderer."
        },
        "mdStudioPreview.preferredViewMode": {
          "type": "string",
          "enum": [
            "auto",
            "slides",
            "stack"
          ],
          "default": "stack",
          "description": "Preferred presentation mode in preview webview. stack matches the web editor view by default."
        },
        "mdStudioPreview.language": {
          "type": "string",
          "enum": [
            "en",
            "ko"
          ],
          "default": "en",
          "description": "Language for MD Studio extension prompts, file browser labels, metadata, and quick pick items."
        },
        "mdStudioPreview.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--standalone"
          ],
          "description": "Additional CLI arguments appended after --base-dir."
        },
        "mdStudioPreview.stripEmailDisclaimer": {
          "type": "boolean",
          "default": false,
          "description": "Remove common corporate email footer/disclaimer text before rendering markdown to HTML."
        },
        "mdStudioPreview.skillsDir": {
          "type": "string",
          "default": "claude_skills/skills",
          "description": "Path to the skills directory used by Template Builder. Relative paths are resolved from workspace root. Absolute paths are also supported."
        },
        "mdStudioPreview.defaultSkill": {
          "type": "string",
          "default": "md-presentation-composer",
          "description": "Preferred skill shown first in Template Builder when matching skills are available."
        },
        "mdStudioFileBrowser.extraExtensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\.?[A-Za-z0-9][A-Za-z0-9_-]*$"
          },
          "default": [],
          "description": "Additional file extensions to show in MD Studio File Browser. Markdown extensions are always included. Examples: txt, html, json."
        }
      }
    },
    "keybindings": [
      {
        "command": "mdStudioFileBrowser.delete",
        "key": "delete",
        "mac": "delete",
        "when": "focusedView == mdStudioFileBrowser && !inputFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mdStudioPreview.openSourceGraph",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioFileBrowser.search",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioFileBrowser.filter",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@2"
        },
        {
          "command": "mdStudioFileBrowser.sort",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@3"
        },
        {
          "command": "mdStudioFileBrowser.configureExtensions",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@4"
        },
        {
          "command": "mdStudioFileBrowser.manageHidden",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@5"
        },
        {
          "command": "mdStudioFileBrowser.refresh",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@6"
        },
        {
          "command": "mdStudioPreview.downloadSkillFolder",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@7"
        },
        {
          "command": "mdStudioPreview.clearFolderFocus",
          "when": "view == mdStudioFileBrowser && mdStudioPreview.folderFocusActive",
          "group": "navigation@8"
        },
        {
          "command": "mdStudioPreview.openSourceGraph",
          "when": "view == mdStudioSourceGraphLauncher",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioPreview.initializeSourceGraphWorkspace",
          "when": "view == mdStudioSourceGraphLauncher",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioPreview.updateSourceGraph",
          "when": "view == mdStudioSourceGraphLauncher",
          "group": "navigation@2"
        },
        {
          "command": "mdStudioPreview.openSourceIgnoreFile",
          "when": "view == mdStudioSourceGraphLauncher",
          "group": "navigation@3"
        },
        {
          "command": "mdStudioPreview.checkCodexMcpStatus",
          "when": "view == mdStudioSourceGraphLauncher",
          "group": "navigation@4"
        }
      ],
      "editor/title": [
        {
          "command": "mdStudioPreview.disableAutoOnSave",
          "when": "(activeWebviewPanelId == 'mdStudioPreview' || activeWebviewPanelId == 'markdown.preview') && mdStudioPreview.autoOnSaveEnabled",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioPreview.enableAutoOnSave",
          "when": "(activeWebviewPanelId == 'mdStudioPreview' || activeWebviewPanelId == 'markdown.preview') && !mdStudioPreview.autoOnSaveEnabled",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioPreview.openSourceEditor",
          "when": "activeWebviewPanelId == 'mdStudioPreview' || activeWebviewPanelId == 'markdown.preview'",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioPreview.disableAutoOnSave",
          "when": "resourceLangId == markdown && mdStudioPreview.autoOnSaveEnabled",
          "group": "navigation@18"
        },
        {
          "command": "mdStudioPreview.enableAutoOnSave",
          "when": "resourceLangId == markdown && !mdStudioPreview.autoOnSaveEnabled",
          "group": "navigation@18"
        },
        {
          "command": "mdStudioPreview.openSourceEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@19"
        },
        {
          "command": "mdStudioPreview.open",
          "when": "resourceLangId == markdown",
          "group": "navigation@20"
        },
        {
          "command": "mdStudioPreview.refresh",
          "when": "resourceLangId == markdown",
          "group": "navigation@21"
        },
        {
          "command": "mdStudioPreview.openTemplateBuilder",
          "when": "resourceLangId == markdown",
          "group": "navigation@22"
        },
        {
          "command": "mdStudioPreview.openSourceGraph",
          "when": "resourceLangId == markdown",
          "group": "navigation@23"
        },
        {
          "command": "mdStudioPreview.transformMarkdownToHtml",
          "when": "resourceLangId == markdown",
          "group": "navigation@24"
        }
      ],
      "view/item/context": [
        {
          "command": "mdStudioFileBrowser.openInEditor",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned)",
          "group": "inline"
        },
        {
          "command": "mdStudioFileBrowser.openInEditor",
          "when": "view == mdStudioFileBrowser && (viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "inline"
        },
        {
          "command": "mdStudioFileBrowser.pinToTop",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdExtraFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile)",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioPreview.clearFolderFocus",
          "when": "view == mdStudioFileBrowser && viewItem == mdFolder && mdStudioPreview.folderFocusActive",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioPreview.focusFolder",
          "when": "view == mdStudioFileBrowser && viewItem == mdFolder",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioFileBrowser.unpin",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@0"
        },
        {
          "command": "mdStudioFileBrowser.openInEditor",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioPreview.openFileInNewPanel",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned)",
          "group": "navigation@2"
        },
        {
          "command": "mdStudioPreview.transformMarkdownToHtml",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned)",
          "group": "navigation@3"
        },
        {
          "command": "mdStudioFileBrowser.copyPath",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@4"
        },
        {
          "command": "mdStudioFileBrowser.copyRelativePath",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@5"
        },
        {
          "command": "mdStudioFileBrowser.copyFileName",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@6"
        },
        {
          "command": "mdStudioFileBrowser.hideItem",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@7"
        },
        {
          "command": "mdStudioFileBrowser.delete",
          "when": "view == mdStudioFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@8"
        }
      ],
      "explorer/context": [
        {
          "command": "mdStudioPreview.transformMarkdownToHtml",
          "when": "resourceLangId == markdown",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "sync:bundle": "node ./tools/sync-cli-bundle.mjs",
    "smoke:bundled-cli": "node ./scripts/md-to-html.mjs --help",
    "build": "npm run sync:bundle && npm run smoke:bundled-cli && tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run build",
    "package:vsix": "vsce package"
  },
  "files": [
    "assets/icon.png",
    "assets/icon.svg",
    "assets/activity-md.svg",
    "assets/activity-source-graph.svg",
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md",
    "EXTENSION_GUIDE.md",
    "source-graph-vsix-preview.png",
    "vscode-extension-0.1.34-updates.png",
    "ai_skills/**",
    "node_modules/sql.js/**",
    "node_modules/yazl/**",
    "node_modules/buffer-crc32/**",
    "scripts/md-to-html.mjs",
    "scripts/source-graph.mjs",
    "public/core/**",
    "public/document.css",
    "public/template-builder-vscode.html"
  ],
  "devDependencies": {
    "@types/node": "^20.17.24",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "sql.js": "^1.10.3",
    "yazl": "^2.5.1"
  }
}
