{
  "name": "markdown-agent-docs",
  "displayName": "Agent Docs for Markdown",
  "description": "Browse Markdown as a source graph, package context, and write better docs with AI agent skills.",
  "version": "0.1.47",
  "publisher": "datanewbie-labs",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sungreong/md-pattern-studio"
  },
  "bugs": {
    "url": "https://github.com/sungreong/md-pattern-studio/issues"
  },
  "homepage": "https://github.com/sungreong/md-pattern-studio#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri",
    "onLanguage:markdown",
    "onView:markdownAgentDocsFileBrowser",
    "onView:markdownAgentDocsSourceGraphLauncher",
    "onCommand:markdownAgentDocs.open",
    "onCommand:markdownAgentDocs.refresh",
    "onCommand:markdownAgentDocs.openSourceEditor",
    "onCommand:markdownAgentDocs.enableAutoOnSave",
    "onCommand:markdownAgentDocs.disableAutoOnSave",
    "onCommand:markdownAgentDocs.openTemplateBuilder",
    "onCommand:markdownAgentDocs.openSourceGraph",
    "onCommand:markdownAgentDocs.initializeSourceGraphWorkspace",
    "onCommand:markdownAgentDocs.updateSourceGraph",
    "onCommand:markdownAgentDocs.searchSourceGraph",
    "onCommand:markdownAgentDocs.openSourceIgnoreFile",
    "onCommand:markdownAgentDocs.openFileInViewer",
    "onCommand:markdownAgentDocs.openFileInNewPanel",
    "onCommand:markdownAgentDocsFileBrowser.openInEditor",
    "onCommand:markdownAgentDocs.transformMarkdownToHtml",
    "onCommand:markdownAgentDocs.downloadSkillFolder",
    "onCommand:markdownAgentDocs.diagnoseEnvironment",
    "onCommand:markdownAgentDocs.focusFolder",
    "onCommand:markdownAgentDocs.clearFolderFocus",
    "onCommand:markdownAgentDocsFileBrowser.refresh",
    "onCommand:markdownAgentDocsFileBrowser.sort",
    "onCommand:markdownAgentDocsFileBrowser.filter",
    "onCommand:markdownAgentDocsFileBrowser.configureExtensions",
    "onCommand:markdownAgentDocsFileBrowser.pinToTop",
    "onCommand:markdownAgentDocsFileBrowser.unpin",
    "onCommand:markdownAgentDocsFileBrowser.copyPath",
    "onCommand:markdownAgentDocsFileBrowser.copyRelativePath",
    "onCommand:markdownAgentDocsFileBrowser.copyFileName",
    "onCommand:markdownAgentDocsFileBrowser.hideItem",
    "onCommand:markdownAgentDocsFileBrowser.delete",
    "onCommand:markdownAgentDocsFileBrowser.manageHidden",
    "onCommand:markdownAgentDocsFileBrowser.search"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownAgentDocsContainer",
          "title": "Agent Docs",
          "icon": "assets/activity-md.svg"
        }
      ]
    },
    "views": {
      "markdownAgentDocsContainer": [
        {
          "id": "markdownAgentDocsSourceGraphLauncher",
          "name": "Source Graph",
          "type": "webview",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "markdownAgentDocsFileBrowser",
          "name": "Markdown Files",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "markdownAgentDocs.open",
        "title": "Agent Docs: Preview"
      },
      {
        "command": "markdownAgentDocs.refresh",
        "title": "Agent Docs: Refresh"
      },
      {
        "command": "markdownAgentDocs.openSourceEditor",
        "title": "Agent Docs: Open Source Editor",
        "icon": "$(edit)"
      },
      {
        "command": "markdownAgentDocs.enableAutoOnSave",
        "title": "Agent Docs: Auto Refresh Off",
        "icon": "$(circle-slash)"
      },
      {
        "command": "markdownAgentDocs.disableAutoOnSave",
        "title": "Agent Docs: Auto Refresh On",
        "icon": "$(sync)"
      },
      {
        "command": "markdownAgentDocs.openTemplateBuilder",
        "title": "Agent Docs: Template Builder",
        "icon": "$(combine)"
      },
      {
        "command": "markdownAgentDocs.openSourceGraph",
        "title": "Agent Docs: Open Source Graph",
        "icon": "$(graph)"
      },
      {
        "command": "markdownAgentDocs.initializeSourceGraphWorkspace",
        "title": "Agent Docs: Initialize Source Graph",
        "icon": "$(database)"
      },
      {
        "command": "markdownAgentDocs.updateSourceGraph",
        "title": "Agent Docs: Update Source Graph",
        "icon": "$(database)"
      },
      {
        "command": "markdownAgentDocs.searchSourceGraph",
        "title": "Agent Docs: Search Source Graph",
        "icon": "$(symbol-keyword)"
      },
      {
        "command": "markdownAgentDocs.openSourceIgnoreFile",
        "title": "Agent Docs: Edit Source Ignore",
        "icon": "$(exclude)"
      },
      {
        "command": "markdownAgentDocs.downloadSkillFolder",
        "title": "Agent Docs: Install or Export Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "markdownAgentDocs.diagnoseEnvironment",
        "title": "Agent Docs: Diagnose Environment",
        "icon": "$(pulse)"
      },
      {
        "command": "markdownAgentDocs.focusFolder",
        "title": "Focus This Folder",
        "icon": "$(target)"
      },
      {
        "command": "markdownAgentDocs.clearFolderFocus",
        "title": "Clear Folder Focus",
        "icon": "$(eye)"
      },
      {
        "command": "markdownAgentDocs.transformMarkdownToHtml",
        "title": "Agent Docs: Export Styled HTML",
        "icon": "$(file-code)"
      },
      {
        "command": "markdownAgentDocs.openFileInViewer",
        "title": "Agent Docs: Open in Viewer",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.refresh",
        "title": "Agent Docs: Refresh File Browser",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.openInEditor",
        "title": "Open in Editor",
        "icon": "$(go-to-file)"
      },
      {
        "command": "markdownAgentDocs.openFileInNewPanel",
        "title": "Open in New Panel",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.search",
        "title": "Agent Docs: Search Files",
        "icon": "$(search)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.sort",
        "title": "Agent Docs: Sort Files",
        "icon": "$(list-ordered)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.filter",
        "title": "Agent Docs: Filter Files",
        "icon": "$(filter)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.configureExtensions",
        "title": "Agent Docs: File Extensions",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.pinToTop",
        "title": "Pin to Top",
        "icon": "$(pinned)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.unpin",
        "title": "Unpin",
        "icon": "$(pinned)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.copyPath",
        "title": "Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.copyRelativePath",
        "title": "Copy Relative Path",
        "icon": "$(copy)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.copyFileName",
        "title": "Copy Name",
        "icon": "$(copy)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.hideItem",
        "title": "Hide from Browser",
        "icon": "$(eye-closed)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "markdownAgentDocsFileBrowser.manageHidden",
        "title": "Agent Docs: Manage Hidden Items",
        "icon": "$(eye)"
      }
    ],
    "configuration": {
      "title": "Agent Docs for Markdown",
      "properties": {
        "markdownAgentDocs.autoOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh an already-open preview when a markdown file is saved."
        },
        "markdownAgentDocs.cursorSyncOnSave": {
          "type": "boolean",
          "default": true,
          "description": "After save render, move preview to the section under the active cursor."
        },
        "markdownAgentDocs.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Node.js executable path used to run scripts/md-to-html.mjs."
        },
        "markdownAgentDocs.cliScriptPath": {
          "type": "string",
          "default": "scripts/md-to-html.mjs",
          "description": "CLI script path. The default value uses the renderer bundled with this extension first, so generated HTML gets the latest viewer controls. Set a custom relative or absolute path to use a workspace renderer."
        },
        "markdownAgentDocs.preferredViewMode": {
          "type": "string",
          "enum": [
            "auto",
            "slides",
            "stack"
          ],
          "default": "stack",
          "description": "Preferred presentation mode in preview webview. stack matches the web editor view by default."
        },
        "markdownAgentDocs.language": {
          "type": "string",
          "enum": [
            "en",
            "ko"
          ],
          "default": "en",
          "description": "Language for Agent Docs extension prompts, file browser labels, metadata, and quick pick items."
        },
        "markdownAgentDocs.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--standalone"
          ],
          "description": "Additional CLI arguments appended after --base-dir."
        },
        "markdownAgentDocs.stripEmailDisclaimer": {
          "type": "boolean",
          "default": false,
          "description": "Remove common corporate email footer/disclaimer text before rendering markdown to HTML."
        },
        "markdownAgentDocs.skillsDir": {
          "type": "string",
          "default": "claude_skills/skills",
          "description": "Path to the skills directory used by Template Builder. Relative paths are resolved from workspace root. Absolute paths are also supported."
        },
        "markdownAgentDocs.defaultSkill": {
          "type": "string",
          "default": "md-presentation-composer",
          "description": "Preferred skill shown first in Template Builder when matching skills are available."
        },
        "markdownAgentDocsFileBrowser.extraExtensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\.?[A-Za-z0-9][A-Za-z0-9_-]*$"
          },
          "default": [],
          "description": "Additional file extensions to show in Agent Docs File Browser. Markdown extensions are always included. Examples: txt, html, json."
        }
      }
    },
    "keybindings": [
      {
        "command": "markdownAgentDocsFileBrowser.delete",
        "key": "delete",
        "mac": "delete",
        "when": "focusedView == markdownAgentDocsFileBrowser && !inputFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "markdownAgentDocs.refresh",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.openSourceEditor",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.enableAutoOnSave",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.disableAutoOnSave",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.openSourceIgnoreFile",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.focusFolder",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.clearFolderFocus",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.openFileInViewer",
          "when": "false"
        },
        {
          "command": "markdownAgentDocs.openFileInNewPanel",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.refresh",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.openInEditor",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.search",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.sort",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.filter",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.configureExtensions",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.pinToTop",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.unpin",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.copyPath",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.copyRelativePath",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.copyFileName",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.hideItem",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.delete",
          "when": "false"
        },
        {
          "command": "markdownAgentDocsFileBrowser.manageHidden",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "markdownAgentDocs.downloadSkillFolder",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@0"
        },
        {
          "command": "markdownAgentDocsFileBrowser.search",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@1"
        },
        {
          "command": "markdownAgentDocsFileBrowser.filter",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@2"
        },
        {
          "command": "markdownAgentDocsFileBrowser.sort",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@3"
        },
        {
          "command": "markdownAgentDocsFileBrowser.configureExtensions",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@4"
        },
        {
          "command": "markdownAgentDocsFileBrowser.manageHidden",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@5"
        },
        {
          "command": "markdownAgentDocsFileBrowser.refresh",
          "when": "view == markdownAgentDocsFileBrowser",
          "group": "navigation@6"
        },
        {
          "command": "markdownAgentDocs.clearFolderFocus",
          "when": "view == markdownAgentDocsFileBrowser && markdownAgentDocs.folderFocusActive",
          "group": "navigation@7"
        },
        {
          "command": "markdownAgentDocs.openSourceGraph",
          "when": "view == markdownAgentDocsSourceGraphLauncher",
          "group": "navigation@0"
        }
      ],
      "editor/title": [
        {
          "command": "markdownAgentDocs.disableAutoOnSave",
          "when": "(activeWebviewPanelId == 'markdownAgentDocs' || activeWebviewPanelId == 'markdown.preview') && markdownAgentDocs.autoOnSaveEnabled",
          "group": "navigation@0"
        },
        {
          "command": "markdownAgentDocs.enableAutoOnSave",
          "when": "(activeWebviewPanelId == 'markdownAgentDocs' || activeWebviewPanelId == 'markdown.preview') && !markdownAgentDocs.autoOnSaveEnabled",
          "group": "navigation@0"
        },
        {
          "command": "markdownAgentDocs.openSourceEditor",
          "when": "activeWebviewPanelId == 'markdownAgentDocs' || activeWebviewPanelId == 'markdown.preview'",
          "group": "navigation@1"
        },
        {
          "command": "markdownAgentDocs.disableAutoOnSave",
          "when": "resourceLangId == markdown && markdownAgentDocs.autoOnSaveEnabled",
          "group": "navigation@18"
        },
        {
          "command": "markdownAgentDocs.enableAutoOnSave",
          "when": "resourceLangId == markdown && !markdownAgentDocs.autoOnSaveEnabled",
          "group": "navigation@18"
        },
        {
          "command": "markdownAgentDocs.openSourceEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@19"
        },
        {
          "command": "markdownAgentDocs.open",
          "when": "resourceLangId == markdown",
          "group": "navigation@20"
        },
        {
          "command": "markdownAgentDocs.refresh",
          "when": "resourceLangId == markdown",
          "group": "navigation@21"
        },
        {
          "command": "markdownAgentDocs.openTemplateBuilder",
          "when": "resourceLangId == markdown",
          "group": "navigation@22"
        },
        {
          "command": "markdownAgentDocs.openSourceGraph",
          "when": "resourceLangId == markdown",
          "group": "navigation@23"
        },
        {
          "command": "markdownAgentDocs.transformMarkdownToHtml",
          "when": "resourceLangId == markdown",
          "group": "navigation@24"
        }
      ],
      "view/item/context": [
        {
          "command": "markdownAgentDocsFileBrowser.openInEditor",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned)",
          "group": "inline"
        },
        {
          "command": "markdownAgentDocsFileBrowser.openInEditor",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "inline"
        },
        {
          "command": "markdownAgentDocsFileBrowser.pinToTop",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdExtraFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile)",
          "group": "navigation@0"
        },
        {
          "command": "markdownAgentDocs.clearFolderFocus",
          "when": "view == markdownAgentDocsFileBrowser && viewItem == mdFolder && markdownAgentDocs.folderFocusActive",
          "group": "navigation@0"
        },
        {
          "command": "markdownAgentDocs.focusFolder",
          "when": "view == markdownAgentDocsFileBrowser && viewItem == mdFolder",
          "group": "navigation@1"
        },
        {
          "command": "markdownAgentDocsFileBrowser.unpin",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@0"
        },
        {
          "command": "markdownAgentDocsFileBrowser.openInEditor",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@1"
        },
        {
          "command": "markdownAgentDocs.openFileInNewPanel",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned)",
          "group": "navigation@2"
        },
        {
          "command": "markdownAgentDocs.transformMarkdownToHtml",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned)",
          "group": "navigation@3"
        },
        {
          "command": "markdownAgentDocsFileBrowser.copyPath",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@4"
        },
        {
          "command": "markdownAgentDocsFileBrowser.copyRelativePath",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@5"
        },
        {
          "command": "markdownAgentDocsFileBrowser.copyFileName",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@6"
        },
        {
          "command": "markdownAgentDocsFileBrowser.hideItem",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@7"
        },
        {
          "command": "markdownAgentDocsFileBrowser.delete",
          "when": "view == markdownAgentDocsFileBrowser && (viewItem == mdFolder || viewItem == mdFile || viewItem == mdFilePinned || viewItem == mdPinnedFile || viewItem == mdRecentFile || viewItem == mdFilterFile || viewItem == mdFilterFilePinned || viewItem == mdExtraFile || viewItem == mdExtraFilePinned || viewItem == mdExtraPinnedFile || viewItem == mdExtraRecentFile || viewItem == mdExtraFilterFile || viewItem == mdExtraFilterFilePinned)",
          "group": "navigation@8"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownAgentDocs.transformMarkdownToHtml",
          "when": "resourceLangId == markdown",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "sync:bundle": "node ./tools/sync-cli-bundle.mjs",
    "smoke:bundled-cli": "node ./scripts/md-to-html.mjs --help",
    "smoke:source-graph": "node ./tools/smoke-source-graph-runtime.mjs",
    "build": "npm run sync:bundle && npm run smoke:bundled-cli && npm run smoke:source-graph && tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run build",
    "package:vsix": "vsce package"
  },
  "files": [
    "assets/icon.png",
    "assets/icon.svg",
    "assets/activity-md.svg",
    "assets/activity-source-graph.svg",
    "dist/**/*.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md",
    "EXTENSION_GUIDE.md",
    "source-graph-vsix-preview.png",
    "vscode-extension-0.1.34-updates.png",
    "ai_skills/**",
    "node_modules/sql.js/package.json",
    "node_modules/sql.js/LICENSE",
    "node_modules/sql.js/dist/sql-wasm.js",
    "node_modules/sql.js/dist/sql-wasm.wasm",
    "node_modules/yazl/package.json",
    "node_modules/yazl/LICENSE",
    "node_modules/yazl/index.js",
    "node_modules/buffer-crc32/package.json",
    "node_modules/buffer-crc32/LICENSE",
    "node_modules/buffer-crc32/index.js",
    "scripts/md-to-html.mjs",
    "scripts/source-graph.mjs",
    "public/core/**",
    "public/document.css",
    "public/template-builder-vscode.html"
  ],
  "devDependencies": {
    "@types/node": "^20.17.24",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "sql.js": "^1.10.3",
    "yazl": "^2.5.1"
  }
}
